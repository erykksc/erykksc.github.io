---
import { heroActions } from '../data/hero';
---

<nav
  class="flex flex-nowrap justify-center gap-2.5 w-[min(31rem,100%)]"
  style="margin-block: clamp(-4.25rem, -4vw, -2.4rem) clamp(-3.8rem, -3.3vw, -2rem);"
  aria-label="Primary actions"
>
  {
    heroActions.map((action, i) => (
      <a
        class="btn-hover flex flex-1 items-center justify-center min-w-0 px-4 py-3.5 border-3 border-border rounded-xl bg-primary text-primary-foreground shadow-hard font-black text-[clamp(0.88rem,1.8vw,1rem)] tracking-wide leading-tight text-center no-underline focus-ring"
        style={
          i === 1
            ? 'background: var(--color-secondary); color: var(--color-foreground); transform: rotate(0.45deg);'
            : ''
        }
        href={action.href}
      >
        {action.label}
      </a>
    ))
  }
</nav>
