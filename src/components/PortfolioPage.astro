---
import TerminalFrame from './TerminalFrame.astro';
import SketchTimeline from './SketchTimeline.astro';
import SocialLinks from './SocialLinks.astro';
import HeroActions from './HeroActions.astro';
import { heroContent, languages } from '../data/hero';
---

<main class="page-shell home-page">
  <section class="hero-copy" aria-labelledby="page-title">
    <div class="profile-photo-slot" aria-label="Profile photo placeholder">
      <span>Photo</span>
    </div>
    <p class="section-kicker">{heroContent.kicker}</p>
    <h1 id="page-title">{heroContent.title}</h1>
    <section class="hero-stats" aria-label="Portfolio highlights">
      <article class="hero-stat">
        <strong>X</strong>
        <span>Open-source projects</span>
      </article>
      <article class="hero-stat">
        <strong>7+</strong>
        <span>Years building software</span>
      </article>
      <article class="hero-stat">
        <strong>5</strong>
        <span>Freelance projects</span>
      </article>
      <article class="hero-stat">
        <strong>X</strong>
        <span>OSS projects contributions</span>
      </article>
    </section>
    <section class="language-list" aria-label="Languages">
      {
        languages.map((lang, i) => {
          const colors = [
            'bg-red-500 text-white',
            'bg-blue-500 text-white',
            'bg-amber-500 text-gray-900',
            'bg-orange-600 text-white',
            'bg-cyan-600 text-white',
          ];
          return (
            <article class={`language-badge ${colors[i] ?? colors[0]}`}>
              <strong class="language-badge__name">{lang.name}</strong>
              <span class="language-badge__level">{lang.level}</span>
            </article>
          );
        })
      }
    </section>
    <SocialLinks />
    <p>{heroContent.description}</p>
    <p class="opacity-60" set:html={heroContent.personalNote} />
  </section>

  <HeroActions />
  <TerminalFrame />
  <SketchTimeline />
</main>
