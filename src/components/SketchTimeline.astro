---
import { Icon } from 'astro-icon/components';
import { timelineItems } from '../data/portfolio';

const categoryIcons = {
  education: { type: 'academic', shape: 'circle' },
  work: { type: 'briefcase', shape: 'square' },
  project: { type: 'code', shape: 'circle' },
} as const;
---

<section class="timeline-section" aria-labelledby="timeline-heading">
  <div class="timeline-heading-block">
    <p class="section-kicker">Projects and achievements</p>
    <h2 id="timeline-heading">A winding record of things I have built</h2>
  </div>

  <div
    class="timeline-canvas"
    style={`--timeline-items: ${timelineItems.length}`}
    data-timeline-canvas
  >
    <svg
      class="timeline-path"
      viewBox="0 0 1000 1650"
      aria-hidden="true"
      preserveAspectRatio="none"
    >
      <path
        pathLength="1"
        d="M182.65 45.83 C96 190 86 320 708 410 C1030 456 950 640 292 755 C-5 805 108 1030 750 1145 C1037.04 1197.62 907.54 1378.42 477.11 1604.17"
      ></path>
    </svg>

    <ol class="timeline-list">
      {
        timelineItems.map((item) => {
          const icon = categoryIcons[item.category];
          return (
            <li
              class:list={['timeline-item', 'timeline-item--circle']}
              data-timeline-item
              data-category={item.category}
            >
              {item.href ? (
                <a
                  class:list={[
                    'timeline-marker',
                    `timeline-marker--${item.image ? 'square' : icon.shape}`,
                    item.image && 'timeline-marker--image',
                  ]}
                  href={item.href}
                  aria-label={`Open ${item.title}`}
                >
                  {item.image ? (
                    <img
                      src={item.image}
                      alt={`Preview of ${item.title}`}
                      loading="lazy"
                    />
                  ) : icon.type === 'github' ? (
                    <Icon
                      name="simple-icons:github"
                      class="timeline-marker-github"
                      aria-hidden="true"
                    />
                  ) : icon.type === 'briefcase' ? (
                    <Icon
                      name="lucide:briefcase-business"
                      class="timeline-marker-icon"
                      aria-hidden="true"
                    />
                  ) : icon.type === 'academic' ? (
                    <Icon
                      name="lucide:graduation-cap"
                      class="timeline-marker-icon"
                      aria-hidden="true"
                    />
                  ) : icon.type === 'spark' ? (
                    <Icon
                      name="lucide:sparkles"
                      class="timeline-marker-icon"
                      aria-hidden="true"
                    />
                  ) : (
                    <Icon
                      name="lucide:code"
                      class="timeline-marker-icon"
                      aria-hidden="true"
                    />
                  )}
                </a>
              ) : (
                <div
                  class:list={[
                    'timeline-marker',
                    `timeline-marker--${item.image ? 'square' : icon.shape}`,
                    item.image && 'timeline-marker--image',
                  ]}
                  aria-hidden="true"
                >
                  {item.image ? (
                    <img src={item.image} alt="" loading="lazy" />
                  ) : icon.type === 'github' ? (
                    <Icon
                      name="simple-icons:github"
                      class="timeline-marker-github"
                      aria-hidden="true"
                    />
                  ) : icon.type === 'briefcase' ? (
                    <Icon
                      name="lucide:briefcase-business"
                      class="timeline-marker-icon"
                      aria-hidden="true"
                    />
                  ) : icon.type === 'academic' ? (
                    <Icon
                      name="lucide:graduation-cap"
                      class="timeline-marker-icon"
                      aria-hidden="true"
                    />
                  ) : icon.type === 'spark' ? (
                    <Icon
                      name="lucide:sparkles"
                      class="timeline-marker-icon"
                      aria-hidden="true"
                    />
                  ) : (
                    <Icon
                      name="lucide:code"
                      class="timeline-marker-icon"
                      aria-hidden="true"
                    />
                  )}
                </div>
              )}
              <article class="timeline-card">
                <p>{item.eyebrow}</p>
                <h3>
                  {item.href ? (
                    <a href={item.href}>{item.title}</a>
                  ) : (
                    item.title
                  )}
                </h3>
                <p>{item.description}</p>
                {item.links && item.links.length > 0 && (
                  <div class="timeline-card-actions">
                    {item.links.map((link) => (
                      <a
                        href={link.href}
                        class="timeline-card-action"
                        data-color={link.color ?? 'yellow'}
                      >
                        {link.label}
                      </a>
                    ))}
                  </div>
                )}
              </article>
            </li>
          );
        })
      }
    </ol>
  </div>
</section>

<script is:inline>
  {
    const canvas = document.querySelector('[data-timeline-canvas]');
    const items = document.querySelectorAll('[data-timeline-item]');
    const reducedMotion = window.matchMedia(
      '(prefers-reduced-motion: reduce)'
    ).matches;

    if (canvas) {
      const path = canvas.querySelector('.timeline-path path');
      const compactTimelineQuery = window.matchMedia('(max-width: 760px)');

      const updateItemPositions = () => {
        if (!path || !items.length || !path.getTotalLength) return;

        if (compactTimelineQuery.matches) {
          canvas.style.removeProperty('min-height');
          return;
        }

        const rootFontSize = Number.parseFloat(
          window.getComputedStyle(document.documentElement).fontSize
        );
        const itemGap = rootFontSize * 2.625;

        canvas.classList.add('is-positioned');

        const totalLength = path.getTotalLength();
        const viewBox = path.ownerSVGElement?.viewBox.baseVal;
        if (!totalLength || !viewBox?.width || !viewBox?.height) return;

        const findPathLengthAtY = (targetY) => {
          let start = 0;
          let end = totalLength;

          for (let step = 0; step < 24; step += 1) {
            const middle = (start + end) / 2;
            const point = path.getPointAtLength(middle);

            if (point.y < targetY) {
              start = middle;
            } else {
              end = middle;
            }
          }

          return (start + end) / 2;
        };

        const cardHeights = Array.from(items).map((item) => {
          const card = item.querySelector('.timeline-card');
          return card?.offsetHeight ?? 0;
        });

        const totalContentHeight =
          cardHeights.reduce((sum, h) => sum + h, 0) +
          itemGap * (items.length + 1);

        canvas.style.minHeight = `${Math.ceil(totalContentHeight)}px`;

        items.forEach((item, index) => {
          let top = itemGap;
          for (let i = 0; i < index; i++) {
            top += cardHeights[i] + itemGap;
          }
          const centerY = top + cardHeights[index] / 2;
          const progress = centerY / totalContentHeight;

          const targetY = viewBox.y + viewBox.height * progress;
          const pathLen = findPathLengthAtY(targetY);
          const point = path.getPointAtLength(pathLen);
          const x = ((point.x - viewBox.x) / viewBox.width) * 100;
          const y = progress * 100;

          item.style.setProperty('--timeline-x', `${x.toFixed(3)}%`);
          item.style.setProperty('--timeline-y', `${y.toFixed(3)}%`);
          item.dataset.cardSide =
            point.x < viewBox.x + viewBox.width / 2 ? 'right' : 'left';
          item.dataset.pathProgress = String(pathLen / totalLength);
        });
      };

      updateItemPositions();

      if (reducedMotion) {
        canvas.style.setProperty('--timeline-progress', '1');
        items.forEach((item) => item.classList.add('is-visible'));
        window.addEventListener('resize', updateItemPositions);
      } else {
        let ticking = false;
        let lastScrollY = window.scrollY || window.pageYOffset;

        const updateProgress = () => {
          const viewportHeight =
            window.innerHeight || document.documentElement.clientHeight;
          const scrollY = window.scrollY || window.pageYOffset;
          const scrollingDown = scrollY > lastScrollY;
          lastScrollY = scrollY;
          const thresholdDocY = scrollY + viewportHeight * 0.92;
          let itemAbove = null;
          let itemBelow = null;

          items.forEach((item) => {
            const itemTop = item.getBoundingClientRect().top + scrollY;
            const itemPathProgress = Number.parseFloat(
              item.dataset.pathProgress
            );

            if (Number.isNaN(itemPathProgress)) return;

            if (itemTop < thresholdDocY) {
              itemAbove = { top: itemTop, pathProgress: itemPathProgress };
            } else if (itemBelow === null) {
              itemBelow = { top: itemTop, pathProgress: itemPathProgress };
            }
          });

          let smoothProgress;
          if (itemAbove === null) {
            if (itemBelow !== null) {
              const canvasTop = canvas.getBoundingClientRect().top + scrollY;
              const range = itemBelow.top - canvasTop;
              const offset = thresholdDocY - canvasTop;
              const factor =
                range > 0 ? Math.max(0, Math.min(1, offset / range)) : 0;
              smoothProgress = factor * itemBelow.pathProgress;
            } else {
              smoothProgress = 0;
            }
          } else if (itemBelow === null) {
            smoothProgress = 1;
          } else {
            const range = itemBelow.top - itemAbove.top;
            const offset = thresholdDocY - itemAbove.top;
            const factor =
              range > 0 ? Math.max(0, Math.min(1, offset / range)) : 0;
            smoothProgress =
              itemAbove.pathProgress +
              factor * (itemBelow.pathProgress - itemAbove.pathProgress);
          }

          canvas.style.setProperty(
            '--timeline-progress',
            smoothProgress.toFixed(4)
          );
          items.forEach((item) => {
            const itemRect = item.getBoundingClientRect();

            if (scrollingDown && itemRect.top < viewportHeight * 0.92) {
              item.classList.add('is-visible');
            } else if (!scrollingDown && itemRect.top > viewportHeight * 0.92) {
              item.classList.remove('is-visible');
            }
          });
          ticking = false;
        };

        const requestUpdate = () => {
          if (ticking) return;
          ticking = true;
          window.requestAnimationFrame(updateProgress);
        };

        const requestLayoutUpdate = () => {
          updateItemPositions();
          requestUpdate();
        };

        updateProgress();
        window.addEventListener('scroll', requestUpdate, { passive: true });
        window.addEventListener('resize', requestLayoutUpdate);
      }
    }
  }
</script>
