---
import { timelineItems } from '../data/portfolio';
---

<section class="timeline-section" aria-labelledby="timeline-heading">
  <div class="timeline-heading-block">
    <p class="section-kicker">Projects and achievements</p>
    <h2 id="timeline-heading">A winding record of things I have built</h2>
  </div>

  <div class="timeline-canvas" data-timeline-canvas>
    <svg
      class="timeline-path"
      viewBox="0 0 1000 1650"
      aria-hidden="true"
      preserveAspectRatio="none"
    >
      <path
        pathLength="1"
        d="M208 95 C96 190 86 320 708 410 C1030 456 950 640 292 755 C-5 805 108 1030 750 1145 C1050 1200 895 1395 417 1635"
      ></path>
    </svg>

    <ol class="timeline-list">
      {
        timelineItems.map((item) => (
          <li
            class:list={[
              'timeline-item',
              `timeline-item--${item.side}`,
              `timeline-item--${item.marker}`,
            ]}
            data-timeline-item
          >
            {item.href ? (
              <a
                class:list={[
                  'timeline-marker',
                  `timeline-marker--${item.media.shape}`,
                ]}
                href={item.href}
                aria-label={`Open ${item.title}`}
              >
                {item.media.type === 'image' && item.media.src ? (
                  <img
                    src={item.media.src}
                    alt={item.media.alt ?? item.title}
                    loading="lazy"
                  />
                ) : item.media.type === 'github' ? (
                  <svg
                    class="timeline-marker-github"
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                  >
                    <path d="M12 .75C5.79.75.75 5.9.75 12.24c0 5.07 3.22 9.38 7.7 10.9.56.1.76-.25.76-.55 0-.27-.01-.99-.01-1.95-3.13.7-3.79-1.54-3.79-1.54-.51-1.33-1.25-1.68-1.25-1.68-1.02-.72.08-.71.08-.71 1.13.08 1.72 1.18 1.72 1.18 1 1.76 2.63 1.25 3.27.96.1-.74.39-1.25.71-1.54-2.5-.29-5.12-1.27-5.12-5.67 0-1.25.44-2.27 1.16-3.08-.11-.29-.51-1.46.11-3.04 0 0 .95-.32 3.09 1.17A10.49 10.49 0 0 1 12 6.28c.96 0 1.91.14 2.81.38 2.15-1.49 3.09-1.17 3.09-1.17.62 1.58.23 2.75.11 3.04.72.81 1.16 1.83 1.16 3.08 0 4.41-2.63 5.37-5.14 5.66.41.36.76 1.06.76 2.14 0 1.54-.01 2.78-.01 3.16 0 .3.2.66.78.55a11.45 11.45 0 0 0 7.69-10.88C23.25 5.9 18.21.75 12 .75Z" />
                  </svg>
                ) : item.media.type === 'terminal' ? (
                  <svg
                    class="timeline-marker-icon"
                    viewBox="0 0 64 64"
                    aria-hidden="true"
                  >
                    <path d="M8 14h48v36H8z" />
                    <path d="M8 23h48M17 18h.1M24 18h.1M31 18h.1M18 34l8 6-8 6M32 45h14" />
                  </svg>
                ) : item.media.type === 'spark' ? (
                  <svg
                    class="timeline-marker-icon"
                    viewBox="0 0 64 64"
                    aria-hidden="true"
                  >
                    <path d="M32 6l6.8 17.2L56 30l-17.2 6.8L32 58l-6.8-21.2L8 30l17.2-6.8L32 6z" />
                    <path d="M48 6l2.8 7.2L58 16l-7.2 2.8L48 26l-2.8-7.2L38 16l7.2-2.8L48 6z" />
                  </svg>
                ) : (
                  <svg
                    class="timeline-marker-icon"
                    viewBox="0 0 64 64"
                    aria-hidden="true"
                  >
                    <path d="M25 18L11 32l14 14M39 18l14 14-14 14M35 12l-6 40" />
                  </svg>
                )}
              </a>
            ) : (
              <div
                class:list={[
                  'timeline-marker',
                  `timeline-marker--${item.media.shape}`,
                ]}
                aria-hidden="true"
              >
                {item.media.type === 'image' && item.media.src ? (
                  <img src={item.media.src} alt="" loading="lazy" />
                ) : item.media.type === 'github' ? (
                  <svg
                    class="timeline-marker-github"
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                  >
                    <path d="M12 .75C5.79.75.75 5.9.75 12.24c0 5.07 3.22 9.38 7.7 10.9.56.1.76-.25.76-.55 0-.27-.01-.99-.01-1.95-3.13.7-3.79-1.54-3.79-1.54-.51-1.33-1.25-1.68-1.25-1.68-1.02-.72.08-.71.08-.71 1.13.08 1.72 1.18 1.72 1.18 1 1.76 2.63 1.25 3.27.96.1-.74.39-1.25.71-1.54-2.5-.29-5.12-1.27-5.12-5.67 0-1.25.44-2.27 1.16-3.08-.11-.29-.51-1.46.11-3.04 0 0 .95-.32 3.09 1.17A10.49 10.49 0 0 1 12 6.28c.96 0 1.91.14 2.81.38 2.15-1.49 3.09-1.17 3.09-1.17.62 1.58.23 2.75.11 3.04.72.81 1.16 1.83 1.16 3.08 0 4.41-2.63 5.37-5.14 5.66.41.36.76 1.06.76 2.14 0 1.54-.01 2.78-.01 3.16 0 .3.2.66.78.55a11.45 11.45 0 0 0 7.69-10.88C23.25 5.9 18.21.75 12 .75Z" />
                  </svg>
                ) : item.media.type === 'terminal' ? (
                  <svg
                    class="timeline-marker-icon"
                    viewBox="0 0 64 64"
                    aria-hidden="true"
                  >
                    <path d="M8 14h48v36H8z" />
                    <path d="M8 23h48M17 18h.1M24 18h.1M31 18h.1M18 34l8 6-8 6M32 45h14" />
                  </svg>
                ) : item.media.type === 'spark' ? (
                  <svg
                    class="timeline-marker-icon"
                    viewBox="0 0 64 64"
                    aria-hidden="true"
                  >
                    <path d="M32 6l6.8 17.2L56 30l-17.2 6.8L32 58l-6.8-21.2L8 30l17.2-6.8L32 6z" />
                    <path d="M48 6l2.8 7.2L58 16l-7.2 2.8L48 26l-2.8-7.2L38 16l7.2-2.8L48 6z" />
                  </svg>
                ) : (
                  <svg
                    class="timeline-marker-icon"
                    viewBox="0 0 64 64"
                    aria-hidden="true"
                  >
                    <path d="M25 18L11 32l14 14M39 18l14 14-14 14M35 12l-6 40" />
                  </svg>
                )}
              </div>
            )}
            <article class="timeline-card">
              <p>{item.eyebrow}</p>
              <h3>
                {item.href ? <a href={item.href}>{item.title}</a> : item.title}
              </h3>
              <p>{item.description}</p>
            </article>
          </li>
        ))
      }
    </ol>
  </div>
</section>

<script is:inline>
  {
    const canvas = document.querySelector('[data-timeline-canvas]');
    const items = document.querySelectorAll('[data-timeline-item]');
    const reducedMotion = window.matchMedia(
      '(prefers-reduced-motion: reduce)'
    ).matches;

    if (canvas) {
      if (reducedMotion) {
        canvas.style.setProperty('--timeline-progress', '1');
        items.forEach((item) => item.classList.add('is-visible'));
      } else {
        let ticking = false;

        const updateProgress = () => {
          const viewportHeight =
            window.innerHeight || document.documentElement.clientHeight;
          const scrollY = window.scrollY || window.pageYOffset;
          const canvasRect = canvas.getBoundingClientRect();
          const canvasTop = canvasRect.top + scrollY;
          const canvasHeight = canvasRect.height;
          const documentHeight = document.documentElement.scrollHeight;
          const maxScroll = Math.max(documentHeight - viewportHeight, 0);
          const progressPoint = scrollY + viewportHeight * 0.73;
          const rawProgress =
            (progressPoint - canvasTop) / (canvasHeight * 0.88);
          const progress =
            scrollY >= maxScroll - 2
              ? 1
              : Math.min(Math.max(rawProgress, 0), 1);

          canvas.style.setProperty('--timeline-progress', progress.toFixed(4));
          items.forEach((item) => {
            const itemRect = item.getBoundingClientRect();
            const isVisible =
              itemRect.bottom > 0 && itemRect.top < viewportHeight * 0.92;

            item.classList.toggle('is-visible', isVisible);
          });
          ticking = false;
        };

        const requestUpdate = () => {
          if (ticking) return;
          ticking = true;
          window.requestAnimationFrame(updateProgress);
        };

        updateProgress();
        window.addEventListener('scroll', requestUpdate, { passive: true });
        window.addEventListener('resize', requestUpdate);
      }
    }
  }
</script>
