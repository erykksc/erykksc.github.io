---
import { Icon } from 'astro-icon/components';
import { timelineItems } from '../data/portfolio';

const categoryIcons = {
  education: { type: 'academic', shape: 'circle' },
  work: { type: 'briefcase', shape: 'square' },
  project: { type: 'code', shape: 'circle' },
} as const;
---

<section class="timeline-section" aria-labelledby="timeline-heading">
  <div class="timeline-heading-block">
    <p class="section-kicker">Projects and achievements</p>
    <h2 id="timeline-heading">A winding record of things I have built</h2>
  </div>

  <div
    class="timeline-canvas"
    style={`--timeline-items: ${timelineItems.length}`}
    data-timeline-canvas
  >
    <svg
      class="timeline-path"
      viewBox="0 0 1000 1650"
      aria-hidden="true"
      preserveAspectRatio="none"
    >
      <path
        pathLength="1"
        d="M208 95 C96 190 86 320 708 410 C1030 456 950 640 292 755 C-5 805 108 1030 750 1145 C1050 1200 895 1395 417 1635"
      ></path>
    </svg>

    <ol class="timeline-list">
      {
        timelineItems.map((item) => {
          const icon = categoryIcons[item.category];
          return (
            <li
              class:list={['timeline-item', 'timeline-item--circle']}
              data-timeline-item
              data-category={item.category}
            >
              {item.href ? (
                <a
                  class:list={[
                    'timeline-marker',
                    `timeline-marker--${icon.shape}`,
                  ]}
                  href={item.href}
                  aria-label={`Open ${item.title}`}
                >
                  {icon.type === 'image' && icon.src ? (
                    <img
                      src={icon.src}
                      alt={icon.alt ?? item.title}
                      loading="lazy"
                    />
                  ) : icon.type === 'github' ? (
                    <Icon
                      name="simple-icons:github"
                      class="timeline-marker-github"
                      aria-hidden="true"
                    />
                  ) : icon.type === 'briefcase' ? (
                    <Icon
                      name="lucide:briefcase-business"
                      class="timeline-marker-icon"
                      aria-hidden="true"
                    />
                  ) : icon.type === 'academic' ? (
                    <Icon
                      name="lucide:graduation-cap"
                      class="timeline-marker-icon"
                      aria-hidden="true"
                    />
                  ) : icon.type === 'spark' ? (
                    <Icon
                      name="lucide:sparkles"
                      class="timeline-marker-icon"
                      aria-hidden="true"
                    />
                  ) : (
                    <Icon
                      name="lucide:code"
                      class="timeline-marker-icon"
                      aria-hidden="true"
                    />
                  )}
                </a>
              ) : (
                <div
                  class:list={[
                    'timeline-marker',
                    `timeline-marker--${icon.shape}`,
                  ]}
                  aria-hidden="true"
                >
                  {icon.type === 'image' && icon.src ? (
                    <img src={icon.src} alt="" loading="lazy" />
                  ) : icon.type === 'github' ? (
                    <Icon
                      name="simple-icons:github"
                      class="timeline-marker-github"
                      aria-hidden="true"
                    />
                  ) : icon.type === 'briefcase' ? (
                    <Icon
                      name="lucide:briefcase-business"
                      class="timeline-marker-icon"
                      aria-hidden="true"
                    />
                  ) : icon.type === 'academic' ? (
                    <Icon
                      name="lucide:graduation-cap"
                      class="timeline-marker-icon"
                      aria-hidden="true"
                    />
                  ) : icon.type === 'spark' ? (
                    <Icon
                      name="lucide:sparkles"
                      class="timeline-marker-icon"
                      aria-hidden="true"
                    />
                  ) : (
                    <Icon
                      name="lucide:code"
                      class="timeline-marker-icon"
                      aria-hidden="true"
                    />
                  )}
                </div>
              )}
              <article class="timeline-card">
                <p>{item.eyebrow}</p>
                <h3>
                  {item.href ? (
                    <a href={item.href}>{item.title}</a>
                  ) : (
                    item.title
                  )}
                </h3>
                <p>{item.description}</p>
              </article>
            </li>
          );
        })
      }
    </ol>
  </div>
</section>

<script is:inline>
  {
    const canvas = document.querySelector('[data-timeline-canvas]');
    const items = document.querySelectorAll('[data-timeline-item]');
    const reducedMotion = window.matchMedia(
      '(prefers-reduced-motion: reduce)'
    ).matches;

    if (canvas) {
      const path = canvas.querySelector('.timeline-path path');
      const compactTimelineQuery = window.matchMedia('(max-width: 760px)');

      const updateItemPositions = () => {
        if (!path || !items.length || !path.getTotalLength) return;

        if (compactTimelineQuery.matches) {
          canvas.style.removeProperty('min-height');
          return;
        }

        const rootFontSize = Number.parseFloat(
          window.getComputedStyle(document.documentElement).fontSize
        );
        const itemGap = rootFontSize * 6;
        const slotHeight =
          Array.from(items).reduce((max, item) => {
            const marker = item.querySelector('.timeline-marker');
            const card = item.querySelector('.timeline-card');
            const markerHeight = marker?.getBoundingClientRect().height ?? 0;
            const cardHeight = card?.getBoundingClientRect().height ?? 0;
            return Math.max(max, markerHeight, cardHeight);
          }, 0) + itemGap;

        canvas.style.minHeight = `${Math.ceil(items.length * slotHeight)}px`;

        const totalLength = path.getTotalLength();
        const viewBox = path.ownerSVGElement?.viewBox.baseVal;
        if (!totalLength || !viewBox?.width || !viewBox?.height) return;

        const getXAtY = (targetY) => {
          let start = 0;
          let end = totalLength;

          for (let step = 0; step < 24; step += 1) {
            const middle = (start + end) / 2;
            const point = path.getPointAtLength(middle);

            if (point.y < targetY) {
              start = middle;
            } else {
              end = middle;
            }
          }

          return path.getPointAtLength((start + end) / 2).x;
        };

        items.forEach((item, index) => {
          const progress = (index + 0.5) / items.length;
          const targetY = viewBox.y + viewBox.height * progress;
          const x = ((getXAtY(targetY) - viewBox.x) / viewBox.width) * 100;
          const y = progress * 100;
          const cardSide = x < 50 ? 'right' : 'left';

          item.style.setProperty('--timeline-x', `${x.toFixed(3)}%`);
          item.style.setProperty('--timeline-y', `${y.toFixed(3)}%`);
          item.dataset.cardSide = cardSide;
        });

        canvas.classList.add('is-positioned');
      };

      updateItemPositions();

      if (reducedMotion) {
        canvas.style.setProperty('--timeline-progress', '1');
        items.forEach((item) => item.classList.add('is-visible'));
        window.addEventListener('resize', updateItemPositions);
      } else {
        let ticking = false;

        const updateProgress = () => {
          const viewportHeight =
            window.innerHeight || document.documentElement.clientHeight;
          const scrollY = window.scrollY || window.pageYOffset;
          const canvasRect = canvas.getBoundingClientRect();
          const canvasTop = canvasRect.top + scrollY;
          const canvasHeight = canvasRect.height;
          const documentHeight = document.documentElement.scrollHeight;
          const maxScroll = Math.max(documentHeight - viewportHeight, 0);
          const progressPoint = scrollY + viewportHeight * 0.73;
          const rawProgress =
            (progressPoint - canvasTop) / (canvasHeight * 0.88);
          const progress =
            scrollY >= maxScroll - 2
              ? 1
              : Math.min(Math.max(rawProgress, 0), 1);

          canvas.style.setProperty('--timeline-progress', progress.toFixed(4));
          items.forEach((item) => {
            const itemRect = item.getBoundingClientRect();
            const isVisible =
              itemRect.bottom > 0 && itemRect.top < viewportHeight * 0.92;

            item.classList.toggle('is-visible', isVisible);
          });
          ticking = false;
        };

        const requestUpdate = () => {
          if (ticking) return;
          ticking = true;
          window.requestAnimationFrame(updateProgress);
        };

        const requestLayoutUpdate = () => {
          updateItemPositions();
          requestUpdate();
        };

        updateProgress();
        window.addEventListener('scroll', requestUpdate, { passive: true });
        window.addEventListener('resize', requestLayoutUpdate);
      }
    }
  }
</script>
