---
import { timelineItems } from '../data/portfolio';
---

<section class="timeline-section" aria-labelledby="timeline-heading">
  <div class="timeline-heading-block">
    <p class="section-kicker">Projects and achievements</p>
    <h2 id="timeline-heading">A winding record of things I have built</h2>
  </div>

  <div class="timeline-canvas">
    <svg class="timeline-path" viewBox="0 0 1000 1650" aria-hidden="true" preserveAspectRatio="none">
      <path
        d="M220 10 C120 120 120 245 285 315 C520 415 745 360 735 555 C725 735 330 675 285 865 C245 1035 655 985 725 1190 C790 1390 350 1330 430 1640"
      />
    </svg>

    <ol class="timeline-list">
      {timelineItems.map((item, index) => (
        <li class:list={['timeline-item', `timeline-item--${item.side}`, `timeline-item--${item.marker}`]}>
          <div class="timeline-marker" aria-hidden="true">
            <span>{String(index + 1).padStart(2, '0')}</span>
          </div>
          <article class="timeline-card">
            <p>{item.eyebrow}</p>
            <h3>{item.title}</h3>
            <p>{item.description}</p>
          </article>
        </li>
      ))}
    </ol>
  </div>
</section>
