---
import { profileName, socialLinks } from '../data/portfolio';
---

<nav class="social-links" aria-label="Social links">
  {
    socialLinks.map((link) => (
      <a
        class="social-link"
        href={link.href}
        target="_blank"
        rel="noreferrer"
        aria-label={`${profileName} on ${link.label}`}
        data-label={`${profileName} on ${link.label}`}
      >
        {link.label === 'GitHub' ? (
          <svg
            class="social-link-icon social-link-icon--github"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path d="M12 .75C5.79.75.75 5.9.75 12.24c0 5.07 3.22 9.38 7.7 10.9.56.1.76-.25.76-.55 0-.27-.01-.99-.01-1.95-3.13.7-3.79-1.54-3.79-1.54-.51-1.33-1.25-1.68-1.25-1.68-1.02-.72.08-.71.08-.71 1.13.08 1.72 1.18 1.72 1.18 1 1.76 2.63 1.25 3.27.96.1-.74.39-1.25.71-1.54-2.5-.29-5.12-1.27-5.12-5.67 0-1.25.44-2.27 1.16-3.08-.11-.29-.51-1.46.11-3.04 0 0 .95-.32 3.09 1.17A10.49 10.49 0 0 1 12 6.28c.96 0 1.91.14 2.81.38 2.15-1.49 3.09-1.17 3.09-1.17.62 1.58.23 2.75.11 3.04.72.81 1.16 1.83 1.16 3.08 0 4.41-2.63 5.37-5.14 5.66.41.36.76 1.06.76 2.14 0 1.54-.01 2.78-.01 3.16 0 .3.2.66.78.55a11.45 11.45 0 0 0 7.69-10.88C23.25 5.9 18.21.75 12 .75Z" />
          </svg>
        ) : (
          <svg class="social-link-icon" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M20.45 20.45h-3.56v-5.58c0-1.33-.03-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.68H9.34V8.98h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.3ZM5.32 7.41a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12Zm1.78 13.04H3.54V8.98H7.1v11.47ZM22.23 0H1.77C.8 0 0 .77 0 1.72v20.56C0 23.23.8 24 1.77 24h20.46c.98 0 1.77-.77 1.77-1.72V1.72C24 .77 23.2 0 22.23 0Z" />
          </svg>
        )}
      </a>
    ))
  }
</nav>
