---
import Layout from '../layouts/Layout.astro';
import TerminalFrame from '../components/TerminalFrame.astro';
import SketchTimeline from '../components/SketchTimeline.astro';
import SocialLinks from '../components/SocialLinks.astro';
import { defaultSection } from '../data/portfolio';
---

<Layout title="Software Developer Portfolio" description="Software developer portfolio with terminal-style sections, projects, experience, and a visual timeline.">
	<main class="page-shell home-page">
		<section class="hero-copy" aria-labelledby="page-title">
			<div class="profile-photo-slot" aria-label="Profile photo placeholder">
				<span>Photo</span>
			</div>
			<p class="section-kicker">Software developer portfolio</p>
			<h1 id="page-title">I build software with a systems mindset and a product focus.</h1>
			<p>
				Replace this introduction with a short, specific summary of who you are, what you build,
				and what kind of work you want to be known for.
			</p>
		</section>

		<SocialLinks />
		<TerminalFrame section={defaultSection} />
		<SketchTimeline />
	</main>
</Layout>
