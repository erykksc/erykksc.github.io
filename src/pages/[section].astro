---
import Layout from '../layouts/Layout.astro';
import PortfolioPage from '../components/PortfolioPage.astro';
import { getTerminalSection, terminalSections } from '../data/portfolio';

export function getStaticPaths() {
  return terminalSections.map((section) => ({
    params: { section: section.slug },
    props: { section },
  }));
}

const section = Astro.props.section ?? getTerminalSection(Astro.params.section);
---

<Layout title={`${section.heading} | Portfolio`} description={`${section.heading} portfolio section.`}>
  <PortfolioPage section={section} />
</Layout>
